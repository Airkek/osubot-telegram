# Telegram bot

# Token from @BotFather
TELEGRAM_TOKEN=654321:BOT_TOKEN_EXAMPLE

# Telegram ID of the bot owner
TELEGRAM_OWNER_ID=123456

# Discard pending updates when polling starts
IGNORE_OLD_UPDATES=true

# Optional secret used to authenticate webhook requests
TELEGRAM_WEBHOOK_TOKEN=


# Application

# Express listener used by the healthcheck endpoint
APP_HOST=0.0.0.0
APP_PORT=3000

# Public statistics dashboard
GRAFANA_LINK=https://your_link/


# Local Telegram Bot API

# Before switching between the official and local APIs, log the bot out:
# https://api.telegram.org/bot<token>/logOut
TELEGRAM_USE_LOCAL_API=true
TELEGRAM_LOCAL_API_HOST=http://telegram_api:8081

# Telegram API credentials used by Docker Compose
# https://core.telegram.org/api/obtaining_api_id
TELEGRAM_APP_API_ID=12345
TELEGRAM_APP_API_HASH=0123456789abcdef1234567890abcdef

# Allow bots where bot_user_id % modulo == remainder
TELEGRAM_LOCAL_API_FILTER_MODULO=1
TELEGRAM_LOCAL_API_FILTER_REMAINDER=0


# osu! API and account linking

# osu! API v2 credentials
OSU_V2_APP_ID=12345
OSU_V2_CLIENT_SECRET=secret

# Optional osu! OAuth link service; leave both empty to disable it
OSU_LINK_API_URL=
OSU_LINK_PAGE_URL=


# Replay rendering

RENDER_REPLAYS=false

# o!rdr credentials
ORDR_USERNAME=osubot-telegram
ORDR_API_KEY=123456asdfg

# Set to "disabled" when the experimental renderer is unavailable
EXPERIMENTAL_RENDERER_BASE_URL=http://experimental_render:9732


# PostgreSQL

DB_HOST=database
DB_PORT=5432
DB_DATABASE_NAME=osubot_telegram
DB_USERNAME=example_user
DB_PASSWORD=example_password


# Docker Compose storage paths

BOT_DATA_PATH=./osubot_data
OSU_BEATMAP_CACHE=./beatmap_cache
DB_DATA_LOCATION=./osubot_postgres
TELEGRAM_API_DATA_PATH=./local_bot_api_data
