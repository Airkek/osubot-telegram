{
    "name": "osubot-telegram",
    "version": "4.0.0",
    "description": "Multi-platform osu! and Beat Saber chat bot",
    "main": "build/src/main.js",
    "scripts": {
        "test": "npm run build && npm run test:run",
        "test:run": "npm run test:js",
        "test:js": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand",
        "start": "node ./build/src/main.js",
        "preinstall": "node ./tools/generate-version.mjs",
        "build": "npm run clean:build && npm run build:node",
        "clean:build": "node -e \"require('node:fs').rmSync('build', { recursive: true, force: true })\"",
        "build:node": "tsc && tsc-alias && npm run build:locales && npm run build:assets && npm run build:contracts",
        "build:locales": "node ./tools/copy-runtime-files.mjs locales",
        "build:assets": "node ./tools/copy-runtime-files.mjs assets",
        "build:contracts": "node ./tools/copy-runtime-files.mjs contracts",
        "check:layout": "node ./tools/check-source-layout.mjs",
        "lint": "eslint . && npm run check:layout",
        "update": "git pull && npm ci && npm run build"
    },
    "author": "keijia",
    "license": "GPL-3.0-only",
    "repository": {
        "type": "git",
        "url": "https://github.com/Airkek/osubot-telegram"
    },
    "bugs": {
        "url": "https://github.com/Airkek/osubot-telegram/issues"
    },
    "homepage": "https://github.com/Airkek/osubot-telegram#readme",
    "dependencies": {
        "@fluent/bundle": "^0.17.1",
        "@grammyjs/auto-retry": "^2.0.2",
        "@grammyjs/chat-members": "^1.2.0",
        "@grammyjs/files": "^1.1.1",
        "@grammyjs/ratelimiter": "^1.2.1",
        "@grammyjs/runner": "^2.0.3",
        "@grpc/grpc-js": "^1.14.4",
        "@grpc/proto-loader": "^0.8.1",
        "@napi-rs/canvas": "^0.1.77",
        "axios": "^1.18.1",
        "dotenv": "^17.2.1",
        "express": "^5.2.1",
        "grammy": "^1.38.1",
        "pg": "^8.16.3",
        "sharp": "^0.34.3",
        "socket.io-client": "^4.8.3",
        "tslog": "^4.9.3",
        "vk-io": "^4.10.1"
    },
    "devDependencies": {
        "@eslint/js": "^9.34.0",
        "@grammyjs/types": "^3.22.1",
        "@jest/globals": "^30.4.1",
        "@types/node": "^24.3.0",
        "@types/pg": "^8.15.5",
        "eslint": "^9.34.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.4",
        "globals": "^16.3.0",
        "jest": "^30.4.2",
        "prettier": "3.6.2",
        "ts-node": "^10.9.2",
        "tsc-alias": "^1.8.16",
        "typescript": "^5.9.2",
        "typescript-eslint": "^8.41.0"
    }
}
